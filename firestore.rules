rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Blogs collection
    match /blogs/{blogId} {
      // Anyone can read (to support API routes acting as anonymous clients)
      allow read: if true;
      // Only authenticated users (admins) can write
      allow write: if request.auth != null;
      
      // Likes subcollection
      match /likes/{userId} {
        allow read: if true;
        // Users can only manage their own likes
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Newsletter collection
    match /newsletter/{entryId} {
      // Anyone can check if subscribed (get) or subscribe (create)
      allow get, create: if true;
      // Only authenticated users (admins) can list or manage
      allow list, update, delete: if request.auth != null;
    }
    
    // Polls collection
    match /polls/{pollId} {
      // Anyone can view poll results
      allow read: if true;
      // Anyone can vote (updates poll document)
      allow write: if true;
      
      // Votes subcollection
      match /votes/{userId} {
        // Anyone can vote once
        allow create: if true;
        // Anyone can check if they've voted
        allow get: if true;
        allow list: if request.auth != null;
      }
    }
    
    // Featured collection (for the featured blog post ID)
    match /featured/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Security fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

