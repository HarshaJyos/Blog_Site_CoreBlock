rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Blogs collection
    match /blogs/{blogId} {
      // Anyone can read published blogs, admin can read all
      allow read: if resource.data.status == 'published' || request.auth != null;
      // Only authenticated users (admins) can write
      allow write: if request.auth != null;
      
      // Likes subcollection
      match /likes/{userId} {
        allow read: if true;
        // Users can only manage their own likes
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Newsletter collection
    match /newsletter/{entryId} {
      // Anyone can subscribe (create)
      allow create: if true;
      // Only authenticated users (admins) can read/update/delete
      allow read, update, delete: if request.auth != null;
    }
    
    // Polls collection
    match /polls/{pollId} {
      // Anyone can view poll results
      allow read: if true;
      // Authenticated users (admins) can manage polls
      allow write: if request.auth != null;
      
      // Votes subcollection
      match /votes/{userId} {
        // Anyone can vote once
        allow create: if true;
        // Anyone can check if they've voted
        allow get: if true;
        allow list: if request.auth != null;
      }
    }
    
    // Security fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

